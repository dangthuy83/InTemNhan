@{ ViewData["Title"] = "Lỗi"; }
<div class="row justify-content-center mt-5">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm border-danger border-start border-4">
            <div class="card-body">
                <h5 class="text-danger fw-bold mb-3">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>Đã xảy ra lỗi
                </h5>
                @if (TempData["Error"] != null) {
                    <div class="alert alert-warning">@TempData["Error"]</div>
                }
                <p class="text-muted mb-4">
                    Vui lòng kiểm tra lại kết nối database hoặc cấu hình hệ thống.
                </p>
                <div class="d-flex gap-2">
                    <a href="/" class="btn btn-primary btn-sm">
                        <i class="bi bi-house me-1"></i>Về trang chủ
                    </a>
                    <button onclick="history.back()" class="btn btn-outline-secondary btn-sm">
                        <i class="bi bi-arrow-left me-1"></i>Quay lại
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>
